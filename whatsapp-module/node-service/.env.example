PORT=3001
API_SECRET_KEY=change_this_secret
SESSION_PATH=./session
ALLOWED_ORIGIN=http://localhost:9090
DEFAULT_COUNTRY_CODE=20

# تسجيل الرسائل الواردة في Laravel (اختياري — نفس قيمة WHATSAPP_INTERNAL_SECRET في .env لـ Laravel)
# مثال: http://127.0.0.1:8000/api/whatsapp/incoming
LARAVEL_INCOMING_WEBHOOK_URL=
WHATSAPP_INTERNAL_SECRET=

# اختياري: رابط HTML لنسخة واتساب ويب (remote cache). إذا تركتها فارغة تُستخدم الذاكرة المحلية الافتراضية للمكتبة.
# WA_WEB_VERSION_REMOTE=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.1036680724-alpha.html
